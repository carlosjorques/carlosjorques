---
import Layout from '../layouts/Layout.astro';
import ContactCTA from '../components/ContactCTA.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<Layout
	title="About"
	description="About Carlos Jorques, an embedded control systems architect focused on physical systems, automotive software, diagnostics, and technical delivery."
>
	<section class="section about-intro">
		<div class="narrow">
			<p class="eyebrow">About</p>
			<h1>Embedded control systems for physical machines</h1>
			<p class="lead">
				I design and lead production-ready embedded control systems, connecting system intent
				with software, control logic, diagnostics, actuation, safety expectations, and delivery.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container about-grid">
			<article>
				<h2>Professional focus</h2>
				<p>
					Embedded control systems architecture for vehicles and smart machines, with emphasis
					on real-time behavior, production reliability, and clear ownership across disciplines.
				</p>
			</article>
			<article>
				<h2>Technical scope</h2>
				<p>
					Sensing, signal processing, embedded software, control algorithms, diagnostics,
					actuation, safety-related development, A-SPICE expectations, and AUTOSAR-oriented
					integration.
				</p>
			</article>
			<article>
				<h2>Leadership and delivery</h2>
				<p>
					I help teams move from requirements and concepts toward integrated software that can
					be verified, maintained, delivered, and trusted in production environments.
				</p>
			</article>
			<article>
				<h2>Representative experience</h2>
				<p>
					Automotive OEM and Tier 1 contexts across embedded control architecture, diagnostics,
					safety-related work, supplier interaction, and cross-functional delivery.
				</p>
			</article>
			<article>
				<h2>Research foundation</h2>
				<p>
					PhD training in electrical engineering supports rigorous thinking in modeling,
					analysis, and control. Research is secondary evidence for industrial technical
					leadership.
				</p>
			</article>
			<article>
				<h2>Contact path</h2>
				<p>
					For embedded control architecture, automotive control software, or technical
					leadership discussions, use the contact page.
				</p>
				<a href={`${baseUrl}contact/`}>Contact</a>
			</article>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<ContactCTA />
		</div>
	</section>
</Layout>

<style>
	.about-intro h1 {
		margin: 0.45rem 0 0.75rem;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.about-grid article {
		border-top: 1px solid var(--color-border);
		padding-top: 1rem;
	}

	.about-grid h2 {
		margin-bottom: 0.45rem;
		font-size: 1.15rem;
	}

	.about-grid a {
		display: inline-block;
		margin-top: 0.65rem;
		color: var(--color-accent);
		text-decoration: none;
	}

	@media (min-width: 760px) {
		.about-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
