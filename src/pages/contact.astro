---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout
	title="Contact"
	description="Contact Carlos Jorques for embedded control systems architecture, automotive software/control projects, and technical leadership roles."
>
	<section class="section">
		<div class="container contact-grid">
			<div>
				<SectionHeading
					eyebrow="Contact"
					title="Discuss control intelligence for physical systems"
					description="For technical leadership roles, embedded control systems architecture, automotive software/control projects, or discussions around control intelligence for physical systems, feel free to contact me."
				/>
			</div>
			<div class="contact-panel">
				<a href="mailto:email@example.com">
					<span>Email placeholder</span>
					<strong>email@example.com</strong>
				</a>
				<a href="https://www.linkedin.com/in/placeholder">
					<span>LinkedIn placeholder</span>
					<strong>linkedin.com/in/placeholder</strong>
				</a>
				<a href="/cv-placeholder.pdf">
					<span>CV placeholder</span>
					<strong>Download CV</strong>
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 420px;
		gap: clamp(32px, 6vw, 78px);
		align-items: start;
	}

	.contact-panel {
		display: grid;
		gap: 1px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-border);
	}

	.contact-panel a {
		display: grid;
		gap: 6px;
		background: rgba(255, 255, 255, 0.66);
		padding: 22px;
		text-decoration: none;
	}

	.contact-panel a:hover {
		background: var(--color-surface);
	}

	.contact-panel span {
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
	}

	.contact-panel strong {
		font-size: 1.05rem;
		overflow-wrap: anywhere;
	}

	@media (max-width: 850px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
