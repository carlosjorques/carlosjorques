---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout
	title="Contact"
	description="Contact Carlos Jorques for embedded control systems architecture, automotive software/control projects, and technical leadership roles."
>
	<section class="section">
		<div class="container contact-grid">
			<div>
				<SectionHeading
					eyebrow="Contact"
					title="Discuss control intelligence for physical systems"
					description="For technical leadership roles, embedded control systems architecture, automotive software/control projects, or discussions around control intelligence for physical systems, feel free to contact me."
				/>
			</div>
			<div class="contact-panel">
				<div>
					<span>Email</span>
					<strong>Launch TODO: add preferred public email</strong>
				</div>
				<div>
					<span>LinkedIn</span>
					<strong>Launch TODO: add verified LinkedIn profile</strong>
				</div>
				<div>
					<span>CV</span>
					<strong>Launch TODO: add final public CV PDF</strong>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.5rem;
		align-items: start;
	}

	.contact-panel {
		display: grid;
		gap: 1px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-border);
	}

	.contact-panel div {
		display: grid;
		gap: 0.4rem;
		background: var(--color-bg);
		padding: 1rem;
		text-decoration: none;
	}

	.contact-panel span {
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.75rem;
	}

	.contact-panel strong {
		font-size: 1.05rem;
		overflow-wrap: anywhere;
	}

	@media (min-width: 850px) {
		.contact-grid {
			grid-template-columns: minmax(0, 1fr) 320px;
			gap: 2rem;
		}
	}
</style>
