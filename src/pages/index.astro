---
import { getCollection } from 'astro:content';

import Layout from '../layouts/Layout.astro';
import CaseCard from '../components/CaseCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import ExpertiseCard from '../components/ExpertiseCard.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SystemModel from '../components/SystemModel.astro';

const toSlug = (id: string) => id.replace(/\.md$/, '');
const featuredCases = (await getCollection('cases'))
	.filter((entry) => entry.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);
const featuredPosts = (await getCollection('writing'))
	.filter((entry) => entry.data.featured)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 3);
const featuredResearch = (await getCollection('research'))
	.filter((entry) => entry.data.featured)
	.slice(0, 2);

const expertise = [
	{
		title: 'Control system architecture',
		description:
			'Define behavior, interfaces, ownership boundaries, diagnostics, and production constraints across control-heavy embedded systems.',
	},
	{
		title: 'Embedded software and diagnostics',
		description:
			'Connect sensing, signal processing, real-time software, diagnostic logic, actuation, validation, and maintainable delivery.',
	},
	{
		title: 'Technical leadership',
		description:
			'Align controls, software, systems, calibration, safety, suppliers, and delivery stakeholders around reliable physical behavior.',
	},
];
---

<Layout
	title="Carlos Jorques | Embedded Control Systems Architect"
	description="Carlos Jorques leads the design of production-ready embedded control systems for vehicles and smart machines."
>
	<Hero
		name="Carlos Jorques"
		title="Embedded Control Systems Architect"
		phrase="Control Intelligence for Physical Systems"
		body="I lead the design of production-ready embedded control systems for vehicles and smart machines, connecting sensing, signal processing, embedded software, control algorithms, diagnostics, actuation, safety, and delivery."
		credibility="PhD-trained electrical engineer with automotive OEM and Tier 1 experience across embedded control, diagnostics, safety-related development, and cross-functional delivery."
	/>

	<section class="section" aria-labelledby="expertise-heading">
		<div class="container">
			<SectionHeading
				eyebrow="Expertise"
				headingId="expertise-heading"
				title="Embedded control from physical behavior to production software"
				description="A compact view of the engineering layers I work across: architecture, implementation, diagnostics, safety-related development, and cross-functional delivery."
			/>
			<div class="grid three">
				{expertise.map((item) => <ExpertiseCard title={item.title} description={item.description} />)}
			</div>
		</div>
	</section>

	<section class="section" aria-labelledby="system-model-heading">
		<div class="container">
			<SectionHeading
				eyebrow="System model"
				headingId="system-model-heading"
				title="The control chain behind reliable machine behavior"
				description="The site uses this chain as the primary technical visual: from measured physical reality to software decisions and validated behavior."
			/>
			<SystemModel />
		</div>
	</section>

	<section class="section" aria-labelledby="cases-heading">
		<div class="container">
			<SectionHeading
				eyebrow="Selected cases"
				headingId="cases-heading"
				title="Public-safe experience cases"
				description="Generalized examples of embedded control architecture, diagnostics, and technical delivery without confidential product, customer, architecture, calibration, or implementation details."
			/>
			<div class="grid three">
				{featuredCases.map((entry) => <CaseCard slug={toSlug(entry.id)} data={entry.data} />)}
			</div>
		</div>
	</section>

	<section class="section" aria-labelledby="writing-heading">
		<div class="container">
			<SectionHeading
				eyebrow="Featured writing"
				headingId="writing-heading"
				title="Notes on control systems, embedded software, and physical behavior"
				description="Planned and draft articles that define the editorial direction for the site. Drafts are labeled as planned articles until full publication."
			/>
			<div class="grid three">
				{featuredPosts.map((entry) => <PostCard slug={toSlug(entry.id)} data={entry.data} />)}
			</div>
		</div>
	</section>

	<section class="section" aria-labelledby="research-heading">
		<div class="container research-section">
			<SectionHeading
				eyebrow="Research foundation"
				headingId="research-heading"
				title="Research as supporting technical credibility"
				description="Research supports the industrial profile without making the website academic-first."
			/>
			<div class="research-list">
				{
					featuredResearch.map((entry) => (
						<article class="research-item">
							<p class="eyebrow">{entry.data.type}</p>
							<h3>{entry.data.title}</h3>
							<p>{entry.data.summary}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<ContactCTA
				title="Discuss embedded control architecture, diagnostics, or technical leadership for physical systems."
				body="Contact and CV links are intentionally launch placeholders in this first draft until verified public details are ready."
			/>
		</div>
	</section>
</Layout>

<style>
	.research-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.research-item {
		border-top: 1px solid var(--color-border);
		padding-top: 1rem;
	}

	.research-item h3 {
		margin: 0.35rem 0 0.45rem;
	}

	@media (min-width: 760px) {
		.research-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
