---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CaseCard from '../../components/CaseCard.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const toSlug = (id: string) => id.replace(/\.md$/, '');
const cases = (await getCollection('cases')).sort((a, b) => a.data.order - b.data.order);
---

<Layout
	title="Cases"
	description="Public-safe embedded control systems case studies for Carlos Jorques, covering architecture, diagnostics, software integration, and technical delivery."
>
	<section class="section">
		<div class="container">
			<SectionHeading
				eyebrow="Cases"
				title="Experience cases without confidential details"
				description="These generalized cases describe the kind of embedded control systems work I do while avoiding specific OEMs, suppliers, products, architectures, calibration details, internal requirements, or implementation details."
			/>
			<div class="grid three">
				{cases.map((entry) => <CaseCard slug={toSlug(entry.id)} data={entry.data} />)}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<ContactCTA />
		</div>
	</section>
</Layout>
