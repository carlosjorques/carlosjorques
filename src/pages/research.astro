---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactCTA from '../components/ContactCTA.astro';

const researchItems = await getCollection('research');
const featuredItems = researchItems.filter((item) => item.data.featured);
const supportingItems = researchItems.filter((item) => !item.data.featured);
---

<Layout
	title="Research"
	description="Research background for Carlos Jorques, supporting credibility in modeling, analysis, and control for production embedded systems."
>
	<section class="section">
		<div class="narrow">
			<SectionHeading
				eyebrow="Research"
				title="Research foundation for industrial control systems work"
				description="Research supports credibility, but the main identity of this site is industrial technical leadership in embedded control systems."
			/>
			<div class="prose">
				<p>
					My research background provides a foundation in modeling, analysis, and control. My
					professional focus is applying that depth to production embedded systems where
					architecture, safety, software integration, diagnostics, standards, suppliers, and
					delivery constraints matter.
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container research-grid">
			{
				featuredItems.map((item) => (
					<section
						id={item.data.type === 'Selected publications' ? 'publications' : undefined}
						class="panel research-card"
					>
						<p class="eyebrow">{item.data.type}</p>
						<h2>{item.data.title}</h2>
						<p>{item.data.summary}</p>
						{item.data.link && (
							<a href={item.data.link} class="text-link">
								View public link
							</a>
						)}
					</section>
				))
			}
		</div>
	</section>

	{
		supportingItems.length > 0 && (
			<section class="section">
				<div class="container">
					<SectionHeading
						eyebrow="External research profiles"
						title="Public research links"
						description="Add verified public profiles here when Google Scholar, ORCID, university, or publication links are ready."
					/>
					<div class="research-list">
						{supportingItems.map((item) => (
							<div class="panel research-card">
								<p class="eyebrow">{item.data.type}</p>
								<h2>{item.data.title}</h2>
								<p>{item.data.summary}</p>
								{item.data.link && (
									<a href={item.data.link} class="text-link">
										View public link
									</a>
								)}
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	<section class="section">
		<div class="container">
			<ContactCTA />
		</div>
	</section>
</Layout>

<style>
	.research-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.research-card {
		display: grid;
		gap: 0.75rem;
		border-top: 1px solid var(--color-border);
		padding: 1rem 0 0;
	}

	.research-card h2 {
		font-size: 1.15rem;
	}

	.text-link {
		color: var(--color-accent);
		font-weight: 700;
	}

	.research-list {
		display: grid;
		gap: 1.5rem;
	}

	@media (min-width: 760px) {
		.research-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
