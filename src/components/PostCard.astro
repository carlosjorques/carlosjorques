---
interface PostData {
	title: string;
	description: string;
	publishDate: Date;
	category: string;
	tags: string[];
	draft: boolean;
}

interface Props {
	slug: string;
	data: PostData;
}

const { slug, data } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const postUrl = `${baseUrl}writing/${slug}/`;
const label = data.draft ? 'Planned article' : data.publishDate.toLocaleDateString('en', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---

<article class="post-card">
	<p class="eyebrow">{data.category}</p>
	<h3><a href={postUrl}>{data.title}</a></h3>
	<p>{data.description}</p>
	<div class="post-meta">
		<span>{label}</span>
		<ul class="tag-list" aria-label="Tags">
			{data.tags.slice(0, 3).map((tag) => <li class="tag">{tag}</li>)}
		</ul>
	</div>
</article>

<style>
	.post-card {
		display: grid;
		gap: 0.75rem;
		border: 0;
		border-top: 1px solid var(--color-border);
		border-radius: 0;
		background: transparent;
		padding: 1.25rem 0 0;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.post-card:hover {
		border-color: var(--color-accent);
	}

	.post-card h3 {
		font-size: 1.15rem;
		line-height: 1.35;
	}

	.post-card h3 a {
		text-decoration: none;
	}

	.post-card p:not(.eyebrow) {
		line-height: 1.65;
	}

	.post-meta {
		display: grid;
		gap: 0.75rem;
		margin-top: 0.25rem;
	}

	.post-meta span {
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.76rem;
	}
</style>
