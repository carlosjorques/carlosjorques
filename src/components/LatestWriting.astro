---
const baseUrl = import.meta.env.BASE_URL;

const posts = [
	{
		number: '01',
		title: 'Closed-loop thinking',
		description: 'Why feedback remains the central idea behind reliable physical systems.',
		meta: 'Control Systems · Essay',
	},
	{
		number: '02',
		title: 'From model to machine',
		description: 'What changes when a control algorithm leaves simulation and meets real hardware.',
		meta: 'Embedded Software · Notes',
	},
	{
		number: '03',
		title: 'Debugging behavior',
		description: 'A first-principles approach to diagnosing embedded control systems.',
		meta: 'Diagnostics · Essay',
	},
];
---

<section class="latest-writing section" aria-labelledby="latest-writing-heading">
	<div class="writing-inner">
		<div class="writing-intro">
			<p class="eyebrow">Latest writing</p>
			<h2 id="latest-writing-heading">Control, software, diagnostics, and physical behavior.</h2>
			<p>
				I write about control systems, embedded software, diagnostics, and the engineering
				decisions that make physical systems behave reliably in the real world.
			</p>
		</div>
		<ol class="post-list">
			{
				posts.map((post) => (
					<li>
						<article class="post-item">
							<span class="post-number">{post.number}</span>
							<div>
								<h3>{post.title}</h3>
								<p>{post.description}</p>
								<span>{post.meta}</span>
							</div>
							<a href={`${baseUrl}writing/`} aria-label={`View writing page for ${post.title}`}>
								<span aria-hidden="true">&rarr;</span>
							</a>
						</article>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.writing-inner {
		display: grid;
		grid-template-columns: minmax(0, 0.74fr) minmax(0, 1.26fr);
		gap: clamp(2rem, 5vw, 4rem);
		width: min(100%, var(--content-width));
		margin-inline: auto;
	}

	.writing-intro {
		display: grid;
		align-content: start;
		gap: 0.85rem;
	}

	.writing-intro h2 {
		max-width: 420px;
		font-size: clamp(1.55rem, 3vw, 2.45rem);
		line-height: 1.12;
	}

	.writing-intro p:not(.eyebrow) {
		max-width: 460px;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.post-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.post-list li {
		margin: 0;
	}

	.post-item {
		display: grid;
		grid-template-columns: 42px minmax(0, 1fr) 32px;
		gap: 1rem;
		align-items: start;
		border-top: 1px solid var(--color-border);
		padding: 1.1rem 0;
		transition: border-color 0.18s ease;
	}

	.post-list li:last-child .post-item {
		border-bottom: 1px solid var(--color-border);
	}

	.post-number,
	.post-item span {
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.76rem;
		font-weight: 700;
	}

	.post-item h3 {
		margin-bottom: 0.35rem;
		font-size: clamp(1.15rem, 2vw, 1.45rem);
		line-height: 1.25;
	}

	.post-item p {
		max-width: 620px;
		margin-bottom: 0.55rem;
		color: var(--color-muted);
		line-height: 1.6;
	}

	.post-item a {
		display: inline-grid;
		width: 32px;
		height: 32px;
		place-items: center;
		color: var(--color-accent);
		text-decoration: none;
		transition: transform 0.18s ease;
	}

	.post-item a span {
		color: inherit;
		font-size: 0.9rem;
	}

	.post-item:hover {
		border-color: var(--color-accent);
	}

	.post-item:hover a {
		transform: translateX(3px);
	}

	@media (max-width: 850px) {
		.writing-inner {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}

	@media (max-width: 560px) {
		.post-item {
			grid-template-columns: 32px minmax(0, 1fr);
		}

		.post-item a {
			grid-column: 2;
			justify-self: start;
		}
	}
</style>
