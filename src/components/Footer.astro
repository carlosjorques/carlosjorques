---
const baseUrl = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div class="container footer-grid">
		<div>
			<p class="eyebrow">Control Intelligence for Physical Systems</p>
			<p class="footer-text">
				Carlos Jorques designs embedded control systems for vehicles and smart machines,
				connecting sensing, software, diagnostics, actuation, safety, and delivery.
			</p>
		</div>
		<nav aria-label="Secondary navigation">
			<a href={`${baseUrl}research/`}>Research</a>
			<a href={`${baseUrl}research/#publications`}>Publications</a>
			<a href={`${baseUrl}cases/`}>Cases</a>
			<a href={`${baseUrl}writing/`}>Writing</a>
			<a href={`${baseUrl}contact/`}>Contact</a>
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		padding: 1.5rem 2rem;
		background: transparent;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		align-items: start;
	}

	.footer-text {
		max-width: 720px;
		margin-top: 0.45rem;
		font-size: 0.85rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		justify-content: flex-start;
	}

	nav a {
		color: var(--color-text);
		font-size: 0.85rem;
		text-decoration: none;
		opacity: 0.74;
	}

	nav a:hover {
		color: var(--color-accent);
		opacity: 1;
	}

	@media (max-width: 720px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}

		nav {
			justify-content: flex-start;
		}
	}
</style>
