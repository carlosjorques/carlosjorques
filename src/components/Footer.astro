---
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<p class="footer-line">Making complex systems behave reliably.</p>
			<p>© {year} Carlos Jorques. All rights reserved.</p>
			<p>Barcelona, Spain</p>
		</div>
		<nav class="footer-links" aria-label="Footer contact links">
			<a href={`${baseUrl}contact/`} aria-label="Email details on contact page">Email</a>
			<a href={`${baseUrl}contact/`} aria-label="LinkedIn details on contact page">LinkedIn</a>
			<a href={`${baseUrl}contact/`} aria-label="CV details on contact page">CV</a>
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		padding: 0 2.75rem 2rem;
		background: transparent;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(100%, var(--content-width));
		border-top: 1px solid var(--color-border);
		margin-inline: auto;
		padding-top: 1.4rem;
	}

	p {
		color: var(--color-muted);
		font-size: 0.78rem;
	}

	.footer-line {
		margin-bottom: 0.2rem;
		color: var(--color-text);
		font-weight: 700;
		opacity: 0.86;
	}

	.footer-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.85rem 1.2rem;
		justify-content: flex-end;
	}

	a {
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
	}

	@media (max-width: 680px) {
		.site-footer {
			padding: 0 1rem 2rem;
		}

		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
		}

		.footer-links {
			justify-content: flex-start;
		}
	}
</style>
