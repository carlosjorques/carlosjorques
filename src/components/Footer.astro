---
const year = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<p class="footer-line">Turning physical complexity into dependable products.</p>
			<p>© {year} Carlos Jorques. All rights reserved.</p>
		</div>
		<div class="footer-links">
			<nav aria-label="Footer links">
				<a href={`${baseUrl}research/`}>Research</a>
				<a href={`${baseUrl}contact/`}>Contact</a>
			</nav>
			<ul aria-label="Launch placeholders">
				<li>Email TODO</li>
				<li>LinkedIn TODO</li>
				<li>CV TODO</li>
			</ul>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 1rem 2.75rem 2rem;
		background: transparent;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(100%, var(--content-width));
		border-top: 1px solid var(--color-border);
		margin-inline: auto;
		padding-top: 1.55rem;
	}

	p {
		color: var(--color-muted);
		font-size: 0.78rem;
	}

	.footer-line {
		margin-bottom: 0.2rem;
		color: var(--color-text);
		font-weight: 700;
		opacity: 0.86;
	}

	.footer-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.85rem 1.2rem;
		justify-content: flex-end;
	}

	nav,
	ul {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.85rem 1.2rem;
	}

	ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		margin: 0;
	}

	a,
	li {
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
	}

	li {
		color: var(--color-subtle);
	}

	@media (max-width: 680px) {
		.site-footer {
			padding: 2rem 1rem;
		}

		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
		}

		.footer-links {
			justify-content: flex-start;
		}
	}
</style>
