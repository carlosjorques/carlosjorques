---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<p>© {year} Carlos Jorques. All rights reserved.</p>
		<nav aria-label="Social links">
			<a href="https://www.linkedin.com/in/placeholder" aria-label="LinkedIn">in</a>
			<a href="mailto:email@example.com" aria-label="Email">
				<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M4 6h16v12H4z" />
					<path d="m4 7 8 6 8-6" />
				</svg>
			</a>
			<a href="https://github.com/placeholder" aria-label="GitHub">
				<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M12 2.8a9.2 9.2 0 0 0-2.9 17.9c.46.08.63-.2.63-.44v-1.55c-2.56.56-3.1-1.1-3.1-1.1-.42-1.08-1.03-1.37-1.03-1.37-.84-.57.06-.56.06-.56.93.07 1.42.96 1.42.96.82 1.41 2.16 1 2.69.77.08-.6.32-1 .58-1.23-2.04-.23-4.19-1.02-4.19-4.55 0-1 .36-1.83.95-2.48-.1-.23-.41-1.17.09-2.44 0 0 .78-.25 2.53.95A8.8 8.8 0 0 1 12 7.36c.78 0 1.56.1 2.3.3 1.75-1.2 2.52-.95 2.52-.95.5 1.27.19 2.21.1 2.44.6.65.94 1.47.94 2.48 0 3.54-2.15 4.31-4.2 4.54.33.28.62.84.62 1.7v2.4c0 .24.17.53.64.44A9.2 9.2 0 0 0 12 2.8Z" />
				</svg>
			</a>
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		padding: 2.75rem 2.75rem 2rem;
		background: transparent;
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(100%, var(--content-width));
		margin-inline: auto;
	}

	p {
		color: var(--color-muted);
		font-size: 0.78rem;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1.35rem;
	}

	a {
		color: var(--color-text);
		font-size: 1.2rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
	}

	svg {
		width: 22px;
		height: 22px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.7;
	}

	a[aria-label='GitHub'] svg {
		fill: currentColor;
		stroke: none;
	}

	@media (max-width: 680px) {
		.site-footer {
			padding: 2rem 1rem;
		}

		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
