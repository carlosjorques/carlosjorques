---
const steps = [
	{
		name: 'Sensors',
		description: 'define what the system needs to perceive',
	},
	{
		name: 'Signals',
		description: 'process measurements into useful information',
	},
	{
		name: 'Software',
		description: 'architect real-time embedded logic',
	},
	{
		name: 'Control',
		description: 'design algorithms for behavior, safety, and diagnostics',
	},
	{
		name: 'Actuation',
		description: 'connect decisions to physical action',
	},
	{
		name: 'Behavior',
		description: 'validate reliable, purposeful system response',
	},
];
---

<section class="system-model">
	<div class="chain" aria-label="Sensors to behavior control chain">
		{steps.map((step, index) => (
			<>
				<div class="chain-node">
					<strong>{step.name}</strong>
				</div>
				{index < steps.length - 1 && <span class="arrow" aria-hidden="true">-&gt;</span>}
			</>
		))}
	</div>
	<div class="mapping">
		{steps.map((step) => (
			<div>
				<h3>{step.name}</h3>
				<p>{step.description}</p>
			</div>
		))}
	</div>
</section>

<style>
	.system-model {
		display: grid;
		gap: 1.5rem;
	}

	.chain {
		position: relative;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: transparent;
		padding: 1rem;
	}

	.chain::before {
		position: absolute;
		left: 1rem;
		right: 1rem;
		top: 50%;
		height: 1px;
		background: var(--color-border);
		content: '';
	}

	.chain-node {
		position: relative;
		z-index: 1;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		padding: 0.55rem 0.75rem;
	}

	.chain-node strong {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.arrow {
		position: relative;
		z-index: 1;
		color: var(--color-accent);
		font-family: var(--font-mono);
		font-weight: 700;
	}

	.mapping {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-border);
	}

	.mapping div {
		background: var(--color-bg);
		padding: 1rem;
	}

	.mapping h3 {
		margin-bottom: 0.45rem;
		font-size: 1rem;
	}

	.mapping p {
		font-size: 0.9rem;
		line-height: 1.55;
	}

	@media (min-width: 980px) {
		.mapping {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.mapping {
			grid-template-columns: 1fr;
		}
	}
</style>
