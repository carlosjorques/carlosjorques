---
interface Props {
	title?: string;
	body?: string;
}

const {
	title = 'Interested in embedded control architecture, automotive software/control projects, or technical leadership for physical systems?',
	body = 'Contact me via LinkedIn or email.',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<section class="contact-cta">
	<div>
		<p class="eyebrow">Contact</p>
		<h2>{title}</h2>
		<p>{body}</p>
	</div>
	<div class="button-row">
		<a class="button primary" href="https://www.linkedin.com/in/placeholder">LinkedIn</a>
		<a class="button" href="mailto:email@example.com">Email</a>
		<a class="button" href={`${baseUrl}cv-placeholder.pdf`}>Download CV</a>
	</div>
</section>

<style>
	.contact-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 28px;
		align-items: end;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		padding: 42px;
		box-shadow: var(--shadow-line);
	}

	.contact-cta div:first-child {
		display: grid;
		gap: 12px;
		max-width: 760px;
	}

	.contact-cta h2 {
		font-size: 2.35rem;
	}

	@media (max-width: 850px) {
		.contact-cta {
			grid-template-columns: 1fr;
			padding: 28px;
		}

		.contact-cta h2 {
			font-size: 1.9rem;
		}
	}
</style>
