---
interface Props {
	title?: string;
	body?: string;
}

const {
	title = 'Discuss embedded control systems architecture',
	body = 'For technical leadership roles, embedded control systems architecture, automotive software/control projects, or discussions around control intelligence for physical systems, feel free to contact me.',
} = Astro.props;
---

<section class="contact-cta">
	<div>
		<p class="eyebrow">Contact</p>
		<h2>{title}</h2>
		<p>{body}</p>
	</div>
	<div class="button-row">
		<a class="button primary" href="/contact/">Contact me</a>
		<a class="button" href="https://www.linkedin.com/in/placeholder">LinkedIn</a>
		<a class="button" href="/cv-placeholder.pdf">Download CV</a>
	</div>
</section>

<style>
	.contact-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 28px;
		align-items: end;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-surface);
		padding: clamp(24px, 5vw, 42px);
	}

	.contact-cta div:first-child {
		display: grid;
		gap: 12px;
		max-width: 760px;
	}

	.contact-cta h2 {
		font-size: clamp(1.7rem, 3vw, 2.55rem);
	}

	@media (max-width: 850px) {
		.contact-cta {
			grid-template-columns: 1fr;
		}
	}
</style>
