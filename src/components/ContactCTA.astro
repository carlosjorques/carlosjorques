---
interface Props {
	title?: string;
	body?: string;
}

const {
	title = 'Interested in embedded control architecture, automotive software/control projects, or technical leadership for physical systems?',
	body = 'Use the contact page for verified contact details and CV availability.',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<section class="contact-cta">
	<div>
		<p class="eyebrow">Contact</p>
		<h2>{title}</h2>
		<p>{body}</p>
	</div>
	<div class="button-row">
		<a class="button primary" href={`${baseUrl}contact/`}>Contact me</a>
		<a class="button" href={`${baseUrl}cases/`}>View cases</a>
	</div>
</section>

<style>
	.contact-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1.25rem;
		align-items: start;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: transparent;
		padding: 1.25rem;
	}

	.contact-cta div:first-child {
		display: grid;
		gap: 0.6rem;
		max-width: 720px;
	}

	.contact-cta h2 {
		font-size: 1.25rem;
	}

	@media (min-width: 850px) {
		.contact-cta {
			grid-template-columns: minmax(0, 1fr) auto;
		}
	}
</style>
