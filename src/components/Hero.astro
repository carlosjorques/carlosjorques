---
interface Props {
	title: string;
	phrase: string;
	body: string;
	credibility: string;
}

const { title, phrase, body, credibility } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const titleLines =
	title === 'Embedded Control Systems Architect'
		? ['Embedded Control Systems', 'Architect']
		: [title];
---

<section class="hero section">
	<div class="container hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">{phrase}</p>
			<h1>
				{titleLines.map((line) => <span>{line}</span>)}
			</h1>
			<p class="lead">{body}</p>
			<p class="credibility">{credibility}</p>
			<div class="button-row" aria-label="Primary actions">
				<a class="button primary" href={`${baseUrl}contact/`}>Contact me</a>
				<a class="button" href={`${baseUrl}cases/`}>View cases</a>
				<a class="button" href={`${baseUrl}cv-placeholder.pdf`}>Download CV</a>
			</div>
		</div>
		<aside class="hero-panel" aria-label="Recruiter classification">
			<div class="profile-block">
				<strong>Carlos Jorques</strong>
				<span>Embedded Control Systems Architect</span>
			</div>
			<div class="classification-block">
				<span>Focus</span>
				<p>Production embedded control systems for vehicles and smart machines.</p>
			</div>
			<div class="classification-block">
				<span>Domains</span>
				<ul>
					<li>Automotive OEM / Tier 1</li>
					<li>Embedded software</li>
					<li>Control & diagnostics</li>
					<li>Functional safety</li>
				</ul>
			</div>
			<div class="classification-block">
				<span>Standards</span>
				<ul>
					<li>ISO 26262</li>
					<li>A-SPICE</li>
					<li>AUTOSAR-oriented development</li>
				</ul>
			</div>
		</aside>
	</div>
</section>

<style>
	.hero {
		padding-top: 116px;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 380px;
		gap: 72px;
		align-items: end;
	}

	.hero-copy {
		display: grid;
		gap: 24px;
	}

	h1 span {
		display: block;
	}

	.credibility {
		max-width: 850px;
		border-left: 3px solid var(--color-accent);
		padding-left: 16px;
		color: #3f474a;
		font-size: 1rem;
	}

	.hero-panel {
		display: grid;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: rgba(255, 253, 250, 0.78);
		box-shadow: var(--shadow-soft);
	}

	.profile-block,
	.classification-block {
		border-bottom: 1px solid var(--color-border);
		background: rgba(255, 253, 250, 0.82);
		padding: 18px;
	}

	.classification-block:last-child {
		border-bottom: 0;
	}

	.profile-block {
		background: var(--color-surface);
	}

	.profile-block strong,
	.profile-block span,
	.classification-block span {
		display: block;
	}

	.profile-block strong {
		font-size: 1.15rem;
		line-height: 1.25;
	}

	.profile-block span {
		margin-top: 4px;
		color: var(--color-steel);
		font-weight: 650;
		line-height: 1.35;
	}

	.classification-block span {
		margin-bottom: 8px;
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.73rem;
		text-transform: uppercase;
	}

	.classification-block p {
		color: var(--color-text);
		font-size: 0.98rem;
		font-weight: 650;
		line-height: 1.45;
	}

	.classification-block ul {
		display: grid;
		gap: 6px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.classification-block li {
		color: var(--color-text);
		font-size: 0.96rem;
		font-weight: 650;
		line-height: 1.35;
	}

	.classification-block li::before {
		color: var(--color-accent);
		content: '/ ';
		font-family: var(--font-mono);
	}

	@media (max-width: 900px) {
		.hero {
			padding-top: 72px;
		}

		.hero-grid {
			grid-template-columns: 1fr;
			gap: 34px;
		}

		.hero-panel {
			max-width: 540px;
		}
	}
</style>
