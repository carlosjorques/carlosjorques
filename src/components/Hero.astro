---
interface Props {
	title: string;
	phrase: string;
	body: string;
	credibility: string;
}

const { title, phrase, body, credibility } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<section class="hero section">
	<div class="container hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">{phrase}</p>
			<h1>{title}</h1>
			<p class="lead">{body}</p>
			<p class="credibility">{credibility}</p>
			<div class="button-row" aria-label="Primary actions">
				<a class="button primary" href={`${baseUrl}contact/`}>Contact me</a>
				<a class="button" href={`${baseUrl}cases/`}>View cases</a>
				<a class="button" href={`${baseUrl}cv-placeholder.pdf`}>Download CV</a>
			</div>
		</div>
		<aside class="hero-panel" aria-label="Control systems architecture summary">
			<div class="panel-header">
				<span>Technical brief</span>
				<strong>Control Systems Notebook</strong>
			</div>
			<div class="schematic" aria-hidden="true">
				<span>Sensing</span>
				<span>Signals</span>
				<span>Software</span>
				<span>Control</span>
				<span>Diagnostics</span>
				<span>Actuation</span>
			</div>
			<dl>
				<div>
					<dt>Role fit</dt>
					<dd>Lead / principal embedded controls, control systems architecture, technical leadership</dd>
				</div>
				<div>
					<dt>Environment</dt>
					<dd>Automotive OEM / Tier 1 delivery contexts, ISO 26262, A-SPICE, AUTOSAR-oriented development</dd>
				</div>
				<div>
					<dt>Working range</dt>
					<dd>Sensing, software, control, diagnostics, actuation, safety</dd>
				</div>
			</dl>
		</aside>
	</div>
</section>

<style>
	.hero {
		padding-top: 116px;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 380px;
		gap: 72px;
		align-items: end;
	}

	.hero-copy {
		display: grid;
		gap: 24px;
	}

	.credibility {
		max-width: 850px;
		border-left: 3px solid var(--color-accent);
		padding-left: 16px;
		color: #3f474a;
		font-size: 1rem;
	}

	.hero-panel {
		display: grid;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: rgba(255, 253, 250, 0.78);
		box-shadow: var(--shadow-soft);
	}

	.panel-header {
		display: grid;
		gap: 6px;
		border-bottom: 1px solid var(--color-border);
		background: var(--color-surface-cool);
		padding: 18px;
	}

	.panel-header span,
	.panel-header strong {
		display: block;
	}

	.panel-header span,
	.hero-panel dt {
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.73rem;
		text-transform: uppercase;
	}

	.panel-header strong {
		font-size: 0.98rem;
		line-height: 1.45;
	}

	.schematic {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1px;
		background: var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.schematic span {
		position: relative;
		min-height: 54px;
		background: rgba(255, 253, 250, 0.86);
		color: var(--color-steel);
		display: grid;
		place-items: center;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 650;
		text-transform: uppercase;
	}

	.schematic span::after {
		position: absolute;
		right: -7px;
		top: 50%;
		z-index: 1;
		width: 12px;
		height: 1px;
		background: var(--color-accent);
		content: '';
	}

	.schematic span:nth-child(2n)::after,
	.schematic span:last-child::after {
		display: none;
	}

	dl {
		display: grid;
		gap: 1px;
		margin: 0;
		background: var(--color-border);
	}

	dl div {
		background: rgba(255, 253, 250, 0.82);
		padding: 18px;
	}

	dt,
	dd {
		margin: 0;
	}

	dd {
		margin-top: 8px;
		color: var(--color-text);
		font-size: 0.98rem;
		font-weight: 650;
		line-height: 1.45;
	}

	@media (max-width: 900px) {
		.hero {
			padding-top: 72px;
		}

		.hero-grid {
			grid-template-columns: 1fr;
			gap: 34px;
		}

		.hero-panel {
			max-width: 540px;
		}
	}
</style>
