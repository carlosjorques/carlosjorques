---
interface CaseData {
	title: string;
	summary: string;
	role: string;
	capabilities: string[];
	standards: string[];
	domain: string;
}

interface Props {
	slug: string;
	data: CaseData;
}

const { slug, data } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const caseUrl = `${baseUrl}cases/${slug}/`;
const demonstratesByTitle: Record<string, string> = {
	'Embedded Control System Architecture':
		'Ability to define the control system boundary, interfaces, and production architecture.',
	'Control Algorithms and Diagnostics':
		'Ability to connect control logic, diagnostics, and physical system behavior.',
	'Cross-Functional Technical Delivery':
		'Ability to align teams, requirements, suppliers, and delivery constraints.',
};
const demonstrates = demonstratesByTitle[data.title];
---

<article class="case-card">
	<div>
		<p class="eyebrow">{data.domain}</p>
		<h3><a href={caseUrl}>{data.title}</a></h3>
		<p>{data.summary}</p>
		{demonstrates && (
			<p class="demonstrates">
				<strong>Demonstrates:</strong> {demonstrates}
			</p>
		)}
	</div>
	<div class="meta">
		<span>{data.role}</span>
		<ul class="tag-list" aria-label="Capabilities">
			{data.capabilities.slice(0, 3).map((item) => <li class="tag">{item}</li>)}
		</ul>
		<ul class="tag-list" aria-label="Standards and environment">
			{data.standards.slice(0, 2).map((item) => <li class="tag muted">{item}</li>)}
		</ul>
	</div>
</article>

<style>
	.case-card {
		display: grid;
		gap: 28px;
		min-height: 300px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: rgba(255, 253, 250, 0.74);
		padding: 24px;
		box-shadow: var(--shadow-line);
		transition:
			background-color 160ms ease,
			border-color 160ms ease,
			transform 160ms ease;
	}

	.case-card:hover {
		border-color: var(--color-border-strong);
		background: var(--color-surface);
		transform: translateY(-2px);
	}

	.case-card h3 {
		margin: 12px 0 14px;
		font-size: 1.35rem;
		line-height: 1.2;
	}

	.case-card h3 a {
		text-decoration: none;
	}

	.case-card h3 a::after {
		color: var(--color-accent);
		content: ' /';
		font-family: var(--font-mono);
		font-size: 0.85em;
	}

	.case-card p:not(.eyebrow) {
		line-height: 1.65;
	}

	.demonstrates {
		margin-top: 16px;
		color: #3f474a;
		font-size: 0.95rem;
	}

	.demonstrates strong {
		color: var(--color-text);
		font-weight: 700;
	}

	.meta {
		align-self: end;
		display: grid;
		gap: 14px;
	}

	.meta span {
		color: var(--color-steel);
		font-size: 0.92rem;
		font-weight: 650;
	}

	:global(.tag.muted) {
		color: #6d777a;
		background: rgba(229, 236, 236, 0.62);
	}
</style>
