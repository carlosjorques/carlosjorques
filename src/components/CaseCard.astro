---
interface CaseData {
	title: string;
	summary: string;
	role: string;
	capabilities: string[];
	standards: string[];
	domain: string;
}

interface Props {
	slug: string;
	data: CaseData;
}

const { slug, data } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const caseUrl = `${baseUrl}cases/${slug}/`;
---

<article class="case-card">
	<div>
		<p class="eyebrow">{data.domain}</p>
		<h3><a href={caseUrl}>{data.title}</a></h3>
		<p>{data.summary}</p>
	</div>
	<div class="meta">
		<span>{data.role}</span>
		<ul class="tag-list" aria-label="Capabilities">
			{data.capabilities.slice(0, 3).map((item) => <li class="tag">{item}</li>)}
		</ul>
		<ul class="tag-list" aria-label="Standards and environment">
			{data.standards.slice(0, 2).map((item) => <li class="tag muted">{item}</li>)}
		</ul>
	</div>
</article>

<style>
	.case-card {
		display: grid;
		gap: 28px;
		min-height: 300px;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.58);
		padding: 24px;
	}

	.case-card h3 {
		margin: 12px 0 14px;
		font-size: 1.35rem;
		line-height: 1.2;
	}

	.case-card h3 a {
		text-decoration: none;
	}

	.case-card p:not(.eyebrow) {
		line-height: 1.65;
	}

	.meta {
		align-self: end;
		display: grid;
		gap: 14px;
	}

	.meta span {
		color: var(--color-steel);
		font-size: 0.92rem;
		font-weight: 650;
	}

	:global(.tag.muted) {
		color: #6d777a;
		background: rgba(231, 235, 236, 0.54);
	}
</style>
