---
interface CaseData {
	title: string;
	summary: string;
	role: string;
	capabilities: string[];
	standards: string[];
	domain: string;
}

interface Props {
	slug: string;
	data: CaseData;
}

const { slug, data } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const caseUrl = `${baseUrl}cases/${slug}/`;
const demonstratesByTitle: Record<string, string> = {
	'Embedded Control System Architecture':
		'Ability to define the control system boundary, interfaces, and production architecture.',
	'Control Algorithms and Diagnostics':
		'Ability to connect control logic, diagnostics, and physical system behavior.',
	'Cross-Functional Technical Delivery':
		'Ability to align teams, requirements, suppliers, and delivery constraints.',
};
const demonstrates = demonstratesByTitle[data.title];
---

<article class="case-card">
	<div>
		<p class="eyebrow">{data.domain}</p>
		<h3><a href={caseUrl}>{data.title}</a></h3>
		<p>{data.summary}</p>
		{demonstrates && (
			<p class="demonstrates">
				<strong>Demonstrates:</strong> {demonstrates}
			</p>
		)}
	</div>
	<div class="meta">
		<span>{data.role}</span>
		<ul class="tag-list" aria-label="Capabilities">
			{data.capabilities.slice(0, 3).map((item) => <li class="tag">{item}</li>)}
		</ul>
		<ul class="tag-list" aria-label="Standards and environment">
			{data.standards.slice(0, 2).map((item) => <li class="tag muted">{item}</li>)}
		</ul>
	</div>
</article>

<style>
	.case-card {
		display: grid;
		gap: 1rem;
		min-height: 0;
		border: 0;
		border-top: 1px solid var(--color-border);
		border-radius: 0;
		background: transparent;
		padding: 1.25rem 0 0;
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.case-card:hover {
		border-color: var(--color-accent);
	}

	.case-card h3 {
		margin: 0.45rem 0 0.5rem;
		font-size: 1.2rem;
		line-height: 1.3;
	}

	.case-card h3 a {
		text-decoration: none;
	}

	.case-card h3 a::after {
		color: var(--color-accent);
		content: ' ->';
		font-family: var(--font-mono);
		font-size: 0.75em;
	}

	.case-card p:not(.eyebrow) {
		line-height: 1.65;
	}

	.demonstrates {
		margin-top: 0.9rem;
		color: var(--color-text);
		font-size: 0.9rem;
		opacity: 0.82;
	}

	.demonstrates strong {
		color: var(--color-text);
		font-weight: 700;
	}

	.meta {
		align-self: end;
		display: grid;
		gap: 14px;
	}

	.meta span {
		color: var(--color-muted);
		font-size: 0.92rem;
		font-weight: 600;
	}

	:global(.tag.muted) {
		color: var(--color-muted);
		background: transparent;
	}
</style>
