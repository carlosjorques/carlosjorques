---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="section-heading">
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h2>{title}</h2>
	{description && <p>{description}</p>}
</div>

<style>
	.section-heading {
		display: grid;
		gap: 12px;
		max-width: 780px;
		margin-bottom: 28px;
	}

	.section-heading p:not(.eyebrow) {
		font-size: 1.05rem;
		line-height: 1.7;
	}
</style>
