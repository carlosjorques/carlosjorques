---
const baseUrl = import.meta.env.BASE_URL;

const items = [
	{
		number: '01',
		title: 'Writing',
		description:
			'Essays and notes on control systems, embedded software, diagnostics, and physical behavior.',
		href: `${baseUrl}writing/`,
	},
	{
		number: '02',
		title: 'About',
		description: 'Background, experience, education, values, and technical leadership.',
		href: `${baseUrl}about/`,
	},
	{
		number: '03',
		title: 'Work',
		description: 'Research, patents, publications, and selected engineering contributions.',
		href: `${baseUrl}research/`,
	},
	{
		number: '04',
		title: 'Contact',
		description: 'Get in touch by email, LinkedIn, or CV.',
		href: `${baseUrl}contact/`,
	},
];
---

<section class="next-strip" aria-labelledby="next-heading">
	<div class="strip-inner">
		<h2 class="eyebrow" id="next-heading">Where to go next</h2>
		<div class="next-grid">
			{
				items.map((item) => (
					<a href={item.href} class="next-item">
						<span class="item-number">{item.number}</span>
						<span class="item-title">
							{item.title}
							<span aria-hidden="true">&rarr;</span>
						</span>
						<span class="item-description">{item.description}</span>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.next-strip {
		border-block: 1px solid var(--color-border);
		margin-bottom: clamp(3rem, 6vw, 5rem);
	}

	.strip-inner {
		width: min(100%, var(--content-width));
		margin-inline: auto;
	}

	.next-strip .eyebrow {
		padding: 1rem 0;
	}

	.next-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border-top: 1px solid var(--color-border);
	}

	.next-item {
		display: grid;
		min-height: 188px;
		align-content: start;
		gap: 0.8rem;
		border-right: 1px solid var(--color-border);
		padding: 1.15rem 1.2rem 1.25rem 0;
		text-decoration: none;
	}

	.next-item + .next-item {
		padding-left: 1.2rem;
	}

	.next-item:last-child {
		border-right: 0;
	}

	.item-number {
		color: var(--color-subtle);
		font-family: var(--font-mono);
		font-size: 0.76rem;
		font-weight: 700;
	}

	.item-title {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		color: var(--color-text);
		font-size: 1.08rem;
		font-weight: 750;
		line-height: 1.25;
	}

	.item-title span {
		color: var(--color-accent);
		transition: transform 0.18s ease;
	}

	.item-description {
		color: var(--color-muted);
		font-size: 0.94rem;
		line-height: 1.55;
	}

	.next-item:hover {
		color: var(--color-text);
	}

	.next-item:hover .item-title span {
		transform: translateX(3px);
	}

	@media (max-width: 900px) {
		.next-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.next-item:nth-child(2n) {
			border-right: 0;
			padding-right: 0;
		}

		.next-item:nth-child(n + 3) {
			border-top: 1px solid var(--color-border);
		}
	}

	@media (max-width: 620px) {
		.next-grid {
			grid-template-columns: 1fr;
		}

		.next-item,
		.next-item + .next-item {
			min-height: 0;
			border-right: 0;
			border-top: 1px solid var(--color-border);
			padding: 1rem 0;
		}

		.next-item:first-child {
			border-top: 0;
		}
	}
</style>
