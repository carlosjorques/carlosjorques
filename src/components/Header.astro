---
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/cases/', label: 'Cases' },
	{ href: '/writing/', label: 'Writing' },
	{ href: '/about/', label: 'About' },
	{ href: '/contact/', label: 'Contact' },
];

const baseUrl = import.meta.env.BASE_URL;
const withBase = (href: string) => (href === '/' ? baseUrl : `${baseUrl}${href.slice(1)}`);
const path = Astro.url.pathname.replace(baseUrl.replace(/\/$/, ''), '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href={withBase('/')} aria-label="Carlos Jorques home">
			<span class="brand-mark" aria-hidden="true">CJ</span>
			<span>
				<strong>Carlos Jorques</strong>
				<small>Embedded Control Systems Architect</small>
			</span>
		</a>
		<p class="sidebar-bio">
			Control intelligence for physical systems: embedded control, diagnostics, safety-related
			development, and technical delivery.
		</p>
		<nav class="main-nav" aria-label="Main navigation">
			{
				navItems.map((item) => (
					<a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
						{item.label}
					</a>
				))
			}
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 4;
		width: var(--sidebar-width);
		height: 100vh;
		flex-shrink: 0;
		background: var(--color-bg);
	}

	.header-inner {
		display: flex;
		flex-direction: column;
		gap: 1.35rem;
		padding: 4rem 1.5rem 1.5rem;
	}

	.brand {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: 0.9rem;
		color: var(--color-text);
		text-decoration: none;
		text-align: center;
	}

	.brand-mark {
		display: grid;
		width: 112px;
		height: 112px;
		place-items: center;
		border: 1px solid var(--color-border);
		border-radius: 50%;
		background: var(--color-surface);
		color: var(--color-accent);
		font-family: var(--font-mono);
		font-size: 1.45rem;
		font-weight: 800;
		transition: border-color 0.2s ease;
	}

	.brand:hover .brand-mark {
		border-color: var(--color-accent);
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand strong {
		font-size: 1.5rem;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.brand small {
		margin-top: 0.25rem;
		color: var(--color-muted);
		font-size: 0.85rem;
		line-height: 1.45;
	}

	.sidebar-bio {
		max-width: 230px;
		color: var(--color-text);
		font-size: 0.9rem;
		line-height: 1.5;
		opacity: 0.78;
		text-align: center;
	}

	.main-nav {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.85rem;
		margin-top: 0.3rem;
	}

	.main-nav a {
		position: relative;
		color: var(--color-text);
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		opacity: 0.74;
	}

	.main-nav a:hover,
	.main-nav a[aria-current='page'] {
		color: var(--color-accent);
		opacity: 1;
	}

	.main-nav a::after {
		position: absolute;
		bottom: -0.45rem;
		left: 0;
		width: 0;
		height: 3px;
		background: var(--color-accent);
		content: '';
		transition: width 0.2s ease;
	}

	.main-nav a:hover::after,
	.main-nav a[aria-current='page']::after {
		width: 100%;
	}

	@media (max-width: 1024px) {
		.site-header {
			position: relative;
			width: 100%;
			height: auto;
		}

		.header-inner {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.9rem 1rem;
			padding: 1rem 1.5rem;
		}

		.brand {
			flex-direction: row;
			text-align: left;
		}

		.brand-mark {
			width: 72px;
			height: 72px;
			font-size: 1rem;
		}

		.sidebar-bio {
			display: none;
		}

		.main-nav {
			flex-direction: row;
			width: 100%;
			overflow-x: auto;
			padding-bottom: 0.25rem;
		}

		.main-nav a {
			white-space: nowrap;
		}
	}
</style>
