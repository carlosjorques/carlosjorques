---
const navItems = [
	{ href: '/writing/', label: 'Writing' },
	{ href: '/about/', label: 'About' },
	{ href: '/research/', label: 'Work' },
	{ href: '/contact/', label: 'Contact' },
];

const baseUrl = import.meta.env.BASE_URL;
const withBase = (href: string) => (href === '/' ? baseUrl : `${baseUrl}${href.slice(1)}`);
const path = Astro.url.pathname.replace(baseUrl.replace(/\/$/, ''), '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href={withBase('/')} aria-label="Carlos Jorques home">
			<strong>Carlos Jorques</strong>
		</a>
		<nav class="main-nav" aria-label="Main navigation">
			{
				navItems.map((item) => (
					<a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
						{item.label}
					</a>
				))
			}
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: relative;
		z-index: 4;
		background: transparent;
		padding-inline: 2.75rem;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(100%, var(--content-width));
		margin-inline: auto;
		padding: 1.55rem 0 1rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		color: var(--color-text);
		font-family: var(--font-mono);
		text-decoration: none;
	}

	.brand strong {
		font-size: 0.88rem;
		font-weight: 700;
		letter-spacing: 0;
	}

	.main-nav {
		display: flex;
		align-items: center;
		gap: 1.65rem;
	}

	.main-nav a {
		color: var(--color-text);
		border-bottom: 1px solid transparent;
		padding-bottom: 0.18rem;
		font-size: 0.92rem;
		font-weight: 600;
		text-decoration: none;
	}

	.main-nav a:hover,
	.main-nav a[aria-current='page'] {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	@media (max-width: 780px) {
		.site-header {
			padding-inline: 1rem;
		}

		.header-inner {
			align-items: baseline;
			flex-wrap: wrap;
			padding-top: 1.25rem;
		}

		.main-nav {
			width: 100%;
			gap: 1rem;
			overflow-x: auto;
			padding-bottom: 0.25rem;
		}

		.main-nav a {
			white-space: nowrap;
		}
	}
</style>
