---
const navItems = [
	{ href: '/writing/', label: 'Writing' },
	{ href: '/about/', label: 'About' },
	{ href: '/cases/', label: 'Cases' },
	{ href: '/research/', label: 'Research' },
	{ href: '/contact/', label: 'Contact' },
];

const baseUrl = import.meta.env.BASE_URL;
const withBase = (href: string) => (href === '/' ? baseUrl : `${baseUrl}${href.slice(1)}`);
const path = Astro.url.pathname.replace(baseUrl.replace(/\/$/, ''), '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href={withBase('/')} aria-label="Carlos Jorques home">
			<span class="brand-mark" aria-hidden="true">
				<svg viewBox="0 0 32 32" role="img" focusable="false">
					<path d="M16 2.75 27.25 9.2v13.6L16 29.25 4.75 22.8V9.2L16 2.75Z" />
					<path d="M16 2.75V16m11.25-6.8L16 16 4.75 9.2m11.25 20.05V16" />
				</svg>
			</span>
			<strong>Carlos Jorques</strong>
		</a>
		<nav class="main-nav" aria-label="Main navigation">
			{
				navItems.map((item) => (
					<a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
						{item.label}
					</a>
				))
			}
			<span class="theme-icon" aria-hidden="true">◐</span>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: relative;
		z-index: 4;
		background: transparent;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(100% - 5.5rem, var(--content-width));
		margin-inline: auto;
		padding: 1.85rem 0 0.75rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		color: var(--color-text);
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.brand-mark {
		display: grid;
		width: 34px;
		height: 34px;
		place-items: center;
		color: var(--color-text);
	}

	.brand-mark svg {
		width: 34px;
		height: 34px;
		fill: none;
		stroke: currentColor;
		stroke-linejoin: round;
		stroke-width: 1.35;
	}

	.brand strong {
		font-size: 0.95rem;
		font-weight: 700;
	}

	.main-nav {
		display: flex;
		align-items: center;
		gap: 1.65rem;
	}

	.main-nav a {
		color: var(--color-text);
		font-size: 0.98rem;
		font-weight: 600;
		text-decoration: none;
	}

	.main-nav a:hover,
	.main-nav a[aria-current='page'] {
		color: var(--color-accent);
	}

	.theme-icon {
		display: inline-grid;
		width: 28px;
		height: 28px;
		place-items: center;
		color: var(--color-text);
	}

	@media (max-width: 780px) {
		.header-inner {
			align-items: flex-start;
			flex-direction: column;
			width: min(100% - 2rem, var(--content-width));
			padding-top: 1.25rem;
		}

		.main-nav {
			width: 100%;
			gap: 1rem;
			overflow-x: auto;
			padding-bottom: 0.25rem;
		}

		.main-nav a {
			white-space: nowrap;
		}
	}
</style>
